@page
@model BookingTracker.Pages.Outreach.IndexModel
@{
    ViewData["Title"] = "Outreach Log";
}

<div class="container mt-4">
    <div class="page-header">
        <h1 class="display-4">Outreach Log</h1>
        <p class="text-muted">Track all venue communications and follow-ups</p>
    </div>

    <div class="mb-4">
        <a href="/" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <input type="text" id="searchBox" class="form-control" placeholder="Search by venue name...">
                </div>
                <div class="col-md-3">
                    <select id="channelFilter" class="form-select">
                        <option value="">All Channels</option>
                        <option value="0">Email</option>
                        <option value="1">Instagram</option>
                        <option value="2">Facebook</option>
                        <option value="3">Phone</option>
                        <option value="4">In-Person</option>
                        <option value="5">Form</option>
                        <option value="6">Referral</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="resultFilter" class="form-select">
                        <option value="">All Results</option>
                        <option value="0">No Reply</option>
                        <option value="1">Interested</option>
                        <option value="2">Passed</option>
                        <option value="3">Booked</option>
                        <option value="4">Needs Follow-up</option>
                        <option value="5">Bad Fit</option>
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    <span class="text-muted">Total: <span id="logCount" class="badge bg-info">0</span></span>
                </div>
            </div>
        </div>
    </div>

    <div id="outreachContainer" class="loading">
        Loading outreach logs...
    </div>
</div>

@section Scripts {
    <script>
        let allLogs = [];

        async function loadOutreachLogs() {
            try {
                const response = await fetch('/api/outreach');
                allLogs = await response.json();
                displayLogs(allLogs);

                // Add filter listeners
                document.getElementById('searchBox').addEventListener('input', filterLogs);
                document.getElementById('channelFilter').addEventListener('change', filterLogs);
                document.getElementById('resultFilter').addEventListener('change', filterLogs);
            } catch (error) {
                console.error('Error loading outreach logs:', error);
                document.getElementById('outreachContainer').innerHTML = '<div class="alert alert-danger">Error loading outreach logs.</div>';
            }
        }

        function filterLogs() {
            const searchTerm = document.getElementById('searchBox').value.toLowerCase();
            const channelFilter = document.getElementById('channelFilter').value;
            const resultFilter = document.getElementById('resultFilter').value;

            let filtered = allLogs;

            if (searchTerm) {
                filtered = filtered.filter(log => {
                    const venueName = log.venue ? log.venue.name.toLowerCase() : '';
                    return venueName.includes(searchTerm);
                });
            }

            if (channelFilter) {
                filtered = filtered.filter(log => log.channel == channelFilter);
            }

            if (resultFilter) {
                filtered = filtered.filter(log => log.result == resultFilter);
            }

            displayLogs(filtered);
        }

        function displayLogs(logs) {
            const container = document.getElementById('outreachContainer');
            document.getElementById('logCount').textContent = logs.length;

            if (logs.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>No outreach logs found.</p></div>';
                return;
            }

            let html = '<div class="table-responsive">';
            html += '<table class="table table-striped table-hover">';
            html += '<thead><tr>';
            html += '<th>Date</th><th>Venue</th><th>Channel</th><th>Direction</th><th>Summary</th><th>Result</th>';
            html += '</tr></thead><tbody>';

            logs.forEach(log => {
                const venueName = log.venue ? log.venue.name : `Venue ID: ${log.venueId}`;
                const venueLink = log.venue ? `/Venues/Details/${log.venueId}` : '#';
                const date = new Date(log.date).toLocaleDateString();
                const directionBadge = log.direction === 0 ? 'bg-primary' : 'bg-success';
                const directionText = log.direction === 0 ? 'Outbound' : 'Inbound';

                html += `<tr>
                    <td><strong>${date}</strong></td>
                    <td><a href="${venueLink}">${venueName}</a></td>
                    <td><span class="badge bg-info">${getChannelName(log.channel)}</span></td>
                    <td><span class="badge ${directionBadge}">${directionText}</span></td>
                    <td>${log.summary || 'N/A'}</td>
                    <td>${log.result !== null ? `<span class="badge bg-secondary">${getResultName(log.result)}</span>` : '<span class="text-muted">Pending</span>'}</td>
                </tr>`;
            });

            html += '</tbody></table></div>';
            container.innerHTML = html;
        }

        function getChannelName(channel) {
            const channels = ['Email', 'Instagram', 'Facebook', 'Phone', 'In-Person', 'Form', 'Referral'];
            return channels[channel] || 'Unknown';
        }

        function getResultName(result) {
            const results = ['No Reply', 'Interested', 'Passed', 'Booked', 'Needs Follow-up', 'Bad Fit'];
            return results[result] || 'Unknown';
        }

        loadOutreachLogs();
    </script>
}
