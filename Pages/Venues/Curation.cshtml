@page
@model BookingTracker.Pages.Venues.CurationModel
@{
    ViewData["Title"] = "Curation Workflow";
}

<div class="container mt-4">
    <div class="page-header">
        <h1 class="display-4">Curation Workflow</h1>
        <p class="text-muted">Review and approve venues for your booking pipeline</p>
    </div>

    <div class="mb-4">
        <a href="/" class="btn btn-secondary">Back to Dashboard</a>
        <a href="/Venues" class="btn btn-info">All Venues</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <strong>Review Process:</strong> Approve venues worth pursuing, reject obvious bad fits, and adjust priorities.
                </div>
                <div class="col-md-4 text-end">
                    <span class="text-muted">Pending: <span id="venueCount" class="badge bg-warning">0</span></span>
                </div>
            </div>
        </div>
    </div>

    <div id="curationContainer" class="loading">
        Loading venues needing review...
    </div>
</div>

<!-- Modal for Future Contact Reason -->
<div class="modal fade" id="futureContactModal" tabindex="-1" aria-labelledby="futureContactModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="futureContactModalLabel">Reason for Future Contact</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Please provide a reason why this venue is marked for future contact:</p>
                <textarea class="form-control bg-dark text-light border-secondary" id="futureContactReason" rows="4" placeholder="e.g., Not booking until Fall 2027, waiting for venue to open, need to build more repertoire first..."></textarea>
                <div id="reasonError" class="text-danger mt-2" style="display: none;">Please enter a reason before continuing.</div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmFutureContact">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadVenuesForReview() {
            try {
                const response = await fetch('/api/views/new-venues-needing-review');
                const venues = await response.json();

                const container = document.getElementById('curationContainer');
                document.getElementById('venueCount').textContent = venues.length;

                if (venues.length === 0) {
                    container.innerHTML = '<div class="empty-state"><p>No venues awaiting review!</p><a href="/Venues/Create" class="btn btn-primary">Add New Venue</a></div>';
                    return;
                }

                let html = '<div class="row">';

                venues.forEach(venue => {
                    const location = [venue.city, venue.state].filter(Boolean).join(', ') || 'Location not specified';
                    const fitBadgeColor = venue.fitScore >= 4 ? 'success' : venue.fitScore >= 3 ? 'warning' : 'secondary';

                    html += '<div class="col-md-6 mb-4">';
                    html += '<div class="card h-100">';
                    html += '<div class="card-body">';
                    html += `<h5 class="card-title">${venue.name}</h5>`;
                    html += `<p class="card-text text-muted"><small>${location}</small></p>`;

                    html += '<div class="mb-3">';
                    html += `<span class="badge bg-secondary me-2">${getVenueTypeName(venue.venueType)}</span>`;
                    html += `<span class="badge bg-${getPriorityColor(venue.priority)} me-2">${getPriorityName(venue.priority)} Priority</span>`;
                    if (venue.fitScore) {
                        html += `<span class="badge bg-${fitBadgeColor}">Fit: ${venue.fitScore}/5</span>`;
                    }
                    html += '</div>';

                    if (venue.notes) {
                        html += `<p class="card-text"><small>${venue.notes.substring(0, 150)}${venue.notes.length > 150 ? '...' : ''}</small></p>`;
                    }

                    if (venue.bookingContactName || venue.bookingContactEmail) {
                        html += '<hr>';
                        html += `<p class="mb-1"><small><strong>Contact:</strong> ${venue.bookingContactName || 'N/A'}</small></p>`;
                        if (venue.bookingContactEmail) {
                            html += `<p class="mb-0"><small>${venue.bookingContactEmail}</small></p>`;
                        }
                    }

                    html += '</div>';
                    html += '<div class="card-footer bg-transparent">';
                    html += '<div class="d-grid gap-2">';
                    html += `<button class="btn btn-success" onclick="approveVenue(${venue.id})">Approve for Outreach</button>`;
                    html += `<button class="btn btn-warning" onclick="markForFutureContact(${venue.id})">Mark for Future Contact</button>`;
                    html += `<button class="btn btn-danger" onclick="rejectVenue(${venue.id})">Mark as Bad Fit</button>`;
                    html += `<a href="/Venues/Details/${venue.id}" class="btn btn-sm btn-outline-info">View Full Details</a>`;
                    html += '</div>';
                    html += '</div>';
                    html += '</div>';
                    html += '</div>';
                });

                html += '</div>';
                container.innerHTML = html;
            } catch (error) {
                console.error('Error loading venues:', error);
                document.getElementById('curationContainer').innerHTML = '<div class="alert alert-danger">Error loading venues.</div>';
            }
        }

        function getVenueTypeName(type) {
            const types = ['Bar', 'Honky Tonk', 'Restaurant', 'Brewery', 'Private Event', 'Festival', 'Corporate', 'Songwriter Round', 'Other'];
            return types[type] || 'Unknown';
        }

        function getPriorityName(priority) {
            const priorities = ['Low', 'Medium', 'High'];
            return priorities[priority] || 'Unknown';
        }

        function getPriorityColor(priority) {
            switch(priority) {
                case 'High': case 2: return 'danger';
                case 'Medium': case 1: return 'warning';
                case 'Low': case 0: return 'secondary';
                default: return 'secondary';
            }
        }

        async function approveVenue(id) {
            try {
                const venueResponse = await fetch(`/api/venues/${id}`);
                const venue = await venueResponse.json();

                venue.status = 2; // ApprovedTarget
                venue.updatedAt = new Date().toISOString();

                const response = await fetch(`/api/venues/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(venue)
                });

                if (response.ok) {
                    alert('Venue approved!');
                    loadVenuesForReview();
                } else {
                    alert('Error approving venue');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error approving venue');
            }
        }

        async function rejectVenue(id) {
            try {
                const venueResponse = await fetch(`/api/venues/${id}`);
                const venue = await venueResponse.json();

                venue.status = 11; // BadFit
                venue.updatedAt = new Date().toISOString();

                const response = await fetch(`/api/venues/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(venue)
                });

                if (response.ok) {
                    alert('Venue marked as bad fit');
                    loadVenuesForReview();
                } else {
                    alert('Error rejecting venue');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error rejecting venue');
            }
        }

        let currentVenueId = null;

        function markForFutureContact(id) {
            currentVenueId = id;
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('futureContactModal'));
            modal.show();

            // Reset the reason field and error
            document.getElementById('futureContactReason').value = '';
            document.getElementById('reasonError').style.display = 'none';
        }

        // Handle modal confirmation
        document.getElementById('confirmFutureContact').addEventListener('click', async function() {
            const reason = document.getElementById('futureContactReason').value.trim();

            if (!reason) {
                document.getElementById('reasonError').style.display = 'block';
                return;
            }

            try {
                const venueResponse = await fetch(`/api/venues/${currentVenueId}`);
                const venue = await venueResponse.json();

                // Append reason to notes with timestamp
                const timestamp = new Date().toLocaleString();
                const newNote = `[${timestamp}] Marked for Future Contact: ${reason}`;

                if (venue.notes && venue.notes.trim()) {
                    venue.notes = venue.notes + '\n\n' + newNote;
                } else {
                    venue.notes = newNote;
                }

                venue.status = 10; // MarkedForFutureContact
                venue.updatedAt = new Date().toISOString();

                const response = await fetch(`/api/venues/${currentVenueId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(venue)
                });

                if (response.ok) {
                    // Close modal
                    const modal = bootstrap.Modal.getInstance(document.getElementById('futureContactModal'));
                    modal.hide();

                    alert('Venue marked for future contact');
                    loadVenuesForReview();
                } else {
                    alert('Error updating venue');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error updating venue');
            }
        });

        loadVenuesForReview();
    </script>
}
