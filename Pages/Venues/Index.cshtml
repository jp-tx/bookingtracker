@page
@model BookingTracker.Pages.Venues.IndexModel
@{
    ViewData["Title"] = "Venues";
}

<div class="container mt-4">
    <div class="page-header">
        <h1 class="display-4">Venues</h1>
        <p class="text-muted">Manage all venue contacts and tracking</p>
    </div>

    <div class="action-buttons mb-4">
        <div class="row">
            <div class="col-md-8">
                <input type="text" id="searchBox" class="form-control" placeholder="Search venues by name, city, or type...">
            </div>
            <div class="col-md-2">
                <select id="statusFilter" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="0">Research</option>
                    <option value="1">Needs Review</option>
                    <option value="2">Approved</option>
                    <option value="5">Contacted</option>
                    <option value="8">Booked</option>
                    <option value="10">Future Contact</option>
                </select>
            </div>
            <div class="col-md-2">
                <a href="/Venues/Create" class="btn btn-primary w-100">Add Venue</a>
            </div>
        </div>
    </div>

    <!-- Column Visibility Controls -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <a data-bs-toggle="collapse" href="#columnControls" role="button" aria-expanded="false" style="text-decoration: none; color: inherit;">
                        <strong>Column Visibility</strong> <small class="text-muted">(click to expand)</small>
                    </a>
                </div>
                <div class="collapse" id="columnControls">
                    <div class="card-body">
                        <div class="row" id="columnCheckboxes">
                            <!-- Checkboxes will be inserted here by JavaScript -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body p-2">
                    <small class="text-muted">
                        Showing <span id="venueCount">0</span> venues
                        <span class="float-end">
                            <a href="/Venues/Curation" class="btn btn-sm btn-warning">Curation Workflow</a>
                        </span>
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div id="venuesContainer" class="loading">
        Loading venues...
    </div>
</div>

@section Scripts {
    <style>
        .sortable {
            cursor: pointer;
            user-select: none;
            position: relative;
            padding-right: 20px !important;
        }
        .sortable:hover {
            background-color: rgba(0,0,0,0.05);
        }
        .sort-indicator {
            position: absolute;
            right: 5px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.8em;
        }
    </style>
    <script>
        let allVenues = [];
        let sortColumn = null;
        let sortDirection = 'asc';

        // Define all available columns
        const columns = [
            { id: 'name', label: 'Venue Name', default: true },
            { id: 'city', label: 'City', default: true },
            { id: 'state', label: 'State', default: true },
            { id: 'neighborhood', label: 'Neighborhood', default: false },
            { id: 'venueType', label: 'Type', default: true },
            { id: 'status', label: 'Status', default: true },
            { id: 'priority', label: 'Priority', default: true },
            { id: 'fitScore', label: 'Fit Score', default: true },
            { id: 'website', label: 'Website', default: false },
            { id: 'instagram', label: 'Instagram', default: false },
            { id: 'bookingContactName', label: 'Contact Name', default: false },
            { id: 'bookingContactEmail', label: 'Contact Email', default: false },
            { id: 'bookingContactPhone', label: 'Contact Phone', default: false },
            { id: 'bookingFormUrl', label: 'Booking Form', default: false },
            { id: 'preferredContactMethod', label: 'Preferred Contact', default: false },
            { id: 'capacityRoomSize', label: 'Capacity', default: false },
            { id: 'musicFormatFit', label: 'Music Format', default: false },
            { id: 'payNotes', label: 'Pay Notes', default: false },
            { id: 'source', label: 'Source', default: false },
            { id: 'researchConfidence', label: 'Research Confidence', default: false },
            { id: 'nextAction', label: 'Next Action', default: false },
            { id: 'nextFollowUpDate', label: 'Follow-up Date', default: false },
            { id: 'lastContactedDate', label: 'Last Contacted', default: false },
            { id: 'owner', label: 'Owner', default: false },
            { id: 'notes', label: 'Notes', default: false },
            { id: 'createdAt', label: 'Created', default: false },
            { id: 'updatedAt', label: 'Updated', default: false }
        ];

        // Load column visibility preferences from localStorage
        let visibleColumns = {};
        const savedPrefs = localStorage.getItem('venueColumnPrefs');
        if (savedPrefs) {
            visibleColumns = JSON.parse(savedPrefs);
        } else {
            columns.forEach(col => {
                visibleColumns[col.id] = col.default;
            });
        }

        function initColumnControls() {
            const container = document.getElementById('columnCheckboxes');
            let html = '';

            columns.forEach(col => {
                const checked = visibleColumns[col.id] ? 'checked' : '';
                html += `
                    <div class="col-md-3 col-sm-4 col-6 mb-2">
                        <div class="form-check">
                            <input class="form-check-input column-checkbox" type="checkbox"
                                   id="col_${col.id}" value="${col.id}" ${checked}>
                            <label class="form-check-label" for="col_${col.id}">
                                ${col.label}
                            </label>
                        </div>
                    </div>`;
            });

            container.innerHTML = html;

            // Add event listeners
            document.querySelectorAll('.column-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', (e) => {
                    visibleColumns[e.target.value] = e.target.checked;
                    localStorage.setItem('venueColumnPrefs', JSON.stringify(visibleColumns));
                    displayVenues(getFilteredAndSortedVenues());
                });
            });
        }

        async function loadVenues() {
            try {
                const response = await fetch('/api/venues');
                allVenues = await response.json();
                initColumnControls();
                displayVenues(getFilteredAndSortedVenues());

                // Add search listener
                document.getElementById('searchBox').addEventListener('input', filterVenues);
                document.getElementById('statusFilter').addEventListener('change', filterVenues);
            } catch (error) {
                console.error('Error loading venues:', error);
                document.getElementById('venuesContainer').innerHTML =
                    '<div class="alert alert-danger">Error loading venues. Please refresh the page.</div>';
            }
        }

        function filterVenues() {
            displayVenues(getFilteredAndSortedVenues());
        }

        function getFilteredAndSortedVenues() {
            const searchTerm = document.getElementById('searchBox').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;

            let filtered = allVenues;

            if (searchTerm) {
                filtered = filtered.filter(v =>
                    v.name.toLowerCase().includes(searchTerm) ||
                    (v.city && v.city.toLowerCase().includes(searchTerm)) ||
                    (v.state && v.state.toLowerCase().includes(searchTerm)) ||
                    getVenueTypeName(v.venueType).toLowerCase().includes(searchTerm)
                );
            }

            if (statusFilter) {
                filtered = filtered.filter(v => v.status == statusFilter);
            }

            // Apply sorting
            if (sortColumn) {
                filtered = [...filtered].sort((a, b) => {
                    let aVal = getColumnValue(a, sortColumn);
                    let bVal = getColumnValue(b, sortColumn);

                    if (aVal === null || aVal === undefined) aVal = '';
                    if (bVal === null || bVal === undefined) bVal = '';

                    if (typeof aVal === 'string') {
                        aVal = aVal.toLowerCase();
                        bVal = bVal.toLowerCase();
                    }

                    if (aVal < bVal) return sortDirection === 'asc' ? -1 : 1;
                    if (aVal > bVal) return sortDirection === 'asc' ? 1 : -1;
                    return 0;
                });
            }

            return filtered;
        }

        function getColumnValue(venue, column) {
            switch(column) {
                case 'venueType': return getVenueTypeName(venue.venueType);
                case 'status': return getStatusName(venue.status);
                case 'priority': return getPriorityName(venue.priority);
                case 'source': return getSourceName(venue.source);
                case 'researchConfidence': return getConfidenceName(venue.researchConfidence);
                default: return venue[column];
            }
        }

        function sortBy(column) {
            if (sortColumn === column) {
                sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                sortColumn = column;
                sortDirection = 'asc';
            }
            displayVenues(getFilteredAndSortedVenues());
        }

        function displayVenues(venues) {
            const container = document.getElementById('venuesContainer');
            document.getElementById('venueCount').textContent = venues.length;

            if (venues.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">📋</div>
                        <p>No venues found.</p>
                        <a href="/Venues/Create" class="btn btn-primary">Add Your First Venue</a>
                    </div>`;
                return;
            }

            let html = '<div class="table-responsive"><table class="table table-striped table-hover">';
            html += '<thead><tr>';

            // Build headers for visible columns
            columns.forEach(col => {
                if (visibleColumns[col.id]) {
                    const sortIndicator = sortColumn === col.id
                        ? `<span class="sort-indicator">${sortDirection === 'asc' ? '▲' : '▼'}</span>`
                        : '';
                    html += `<th class="sortable" onclick="sortBy('${col.id}')">${col.label}${sortIndicator}</th>`;
                }
            });

            html += '<th>Actions</th>';
            html += '</tr></thead><tbody>';

            venues.forEach(venue => {
                html += '<tr>';

                columns.forEach(col => {
                    if (visibleColumns[col.id]) {
                        html += '<td>' + formatColumnValue(venue, col.id) + '</td>';
                    }
                });

                html += `<td>
                    <div class="btn-group btn-group-sm" role="group">
                        <a href="/Venues/Details/${venue.id}" class="btn btn-info" title="View Details">View</a>
                        <a href="/Venues/Edit/${venue.id}" class="btn btn-warning" title="Edit">Edit</a>
                    </div>
                </td>`;
                html += '</tr>';
            });

            html += '</tbody></table></div>';
            container.innerHTML = html;
        }

        function formatColumnValue(venue, columnId) {
            const value = venue[columnId];

            switch(columnId) {
                case 'name':
                    return `<strong>${venue.name}</strong>`;
                case 'city':
                case 'state':
                case 'neighborhood':
                    return value || '<span class="text-muted">-</span>';
                case 'venueType':
                    return `<span class="badge bg-secondary">${getVenueTypeName(venue.venueType)}</span>`;
                case 'status':
                    return `<span class="badge bg-info">${getStatusName(venue.status)}</span>`;
                case 'priority':
                    return `<span class="badge bg-${getPriorityColor(venue.priority)}">${getPriorityName(venue.priority)}</span>`;
                case 'fitScore':
                    return venue.fitScore
                        ? `<span class="badge ${venue.fitScore >= 4 ? 'bg-success' : venue.fitScore >= 3 ? 'bg-warning' : 'bg-secondary'}">${venue.fitScore}/5</span>`
                        : '<span class="text-muted">-</span>';
                case 'website':
                case 'bookingFormUrl':
                    return value ? `<a href="${value}" target="_blank" class="small">Link</a>` : '<span class="text-muted">-</span>';
                case 'instagram':
                    const instagramHandle = value.replace(/^@@/, '');
                    return value ? `<a href="https://instagram.com/${instagramHandle}" target="_blank" class="small">${value}</a>` : '<span class="text-muted">-</span>';
                case 'bookingContactEmail':
                    return value ? `<a href="mailto:${value}" class="small">${value}</a>` : '<span class="text-muted">-</span>';
                case 'bookingContactPhone':
                    return value ? `<a href="tel:${value}" class="small">${value}</a>` : '<span class="text-muted">-</span>';
                case 'source':
                    return getSourceName(venue.source);
                case 'researchConfidence':
                    return getConfidenceName(venue.researchConfidence);
                case 'nextFollowUpDate':
                case 'lastContactedDate':
                case 'createdAt':
                case 'updatedAt':
                    return value ? new Date(value).toLocaleDateString() : '<span class="text-muted">-</span>';
                case 'notes':
                    return value ? `<small>${value.substring(0, 50)}${value.length > 50 ? '...' : ''}</small>` : '<span class="text-muted">-</span>';
                default:
                    return value || '<span class="text-muted">-</span>';
            }
        }

        function getVenueTypeName(type) {
            const types = ['Bar', 'Honky Tonk', 'Restaurant', 'Brewery', 'Private Event',
                          'Festival', 'Corporate', 'Songwriter Round', 'Other'];
            return types[type] || 'Unknown';
        }

        function getStatusName(status) {
            const statuses = ['Research', 'Review', 'Approved', 'Draft', 'Ready',
                            'Contacted', 'Follow-up', 'In Talk', 'Booked', 'Not Now',
                            'Future Contact', 'Bad Fit', 'No Response', 'Existing'];
            return statuses[status] || 'Unknown';
        }

        function getPriorityName(priority) {
            return ['Low', 'Medium', 'High'][priority] || 'Unknown';
        }

        function getPriorityColor(priority) {
            return priority === 2 ? 'danger' : priority === 1 ? 'warning' : 'secondary';
        }

        function getSourceName(source) {
            const sources = ['User Research', 'User Referral', 'Venue Discovery', 'Previous Gig', 'Inbound', 'Other'];
            return sources[source] || 'Unknown';
        }

        function getConfidenceName(confidence) {
            return ['Low', 'Medium', 'High'][confidence] || 'Unknown';
        }

        loadVenues();
    </script>
}
